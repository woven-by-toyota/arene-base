test_suite(
    name = "minitest_handles_else_without_braces_test",
    tests = [
        name
        for i, assertion in enumerate([
            "SUCCEED()",
            "GTEST_SKIP()",
            "FAIL()",
            "ADD_FAILURE()",
            "ASSERT_TRUE(true)",
            "ASSERT_FALSE(false)",
            "ASSERT_EQ(1, 1)",
            'ASSERT_STREQ("", "")',
            'ASSERT_STRNE("a", "")',
            "ASSERT_NE(0, 1)",
            "ASSERT_LT(0, 1)",
            "ASSERT_LE(0, 1)",
            "ASSERT_GT(1, 0)",
            "ASSERT_GE(1, 0)",
            "ASSERT_NEAR(0, 0, 0)",
            "ASSERT_NO_THROW(0)",
            "ASSERT_THROW(0, int)",
            "ASSERT_THAT(1, ::testing::Eq(1))",
            "EXPECT_TRUE(true)",
            "EXPECT_FALSE(false)",
            "EXPECT_EQ(1, 1)",
            "EXPECT_NE(0, 1)",
            "EXPECT_NO_FATAL_FAILURE(1;)",
            "EXPECT_THAT(1, ::testing::Eq(1))",
        ])
        for name in ["minitest_handles_else_without_braces_{}_test".format(i)]
        for _ in [
            cc_test(
                name = name,
                srcs = ["minitest_handles_else_without_braces_test.cpp"],
                local_defines = ["ASSERTION_UNDER_TEST='{}'".format(assertion)],
                deps = ["//testlibs/minitest"] + (
                    ["//configs:incompatible_with_exceptions_disabled"] if assertion.startswith("ASSERT_THROW") else []
                ),
            ),
        ]
    ],
)
