load("//rules:cc_build_error.bzl", "cc_build_error_test", "inline_src", "matcher")
load("//rules:cc_test.bzl", "cc_test_with_variants")

package(default_visibility = ["//tools/compdb:__subpackages__"])

test_suite(
    name = "choose_quantity_kind_base_error_test",
    tests = [
        subtest
        for subtest, _ in [
            (
                "choose_quantity_kind_base_error_{}_test".format(i),
                cc_build_error_test(
                    name = "choose_quantity_kind_base_error_{}_test".format(i),
                    src = inline_src.cpp("""\
            #include "arene/base/units.hpp"

            class base_kind;
            class base_unit : public arene::base::quantity_unit<base_unit, base_kind> {{}};
            class base_kind : public arene::base::quantity_kind<base_kind, base_unit> {{}};
            class my_origin : public arene::base::quantity_origin<my_origin> {{}};

            auto main() -> int {{
                class my_kind : public arene::base::quantity_kind<{args}> {{}};
            }}
            """.format(
                        args = args,
                    )),
                    compile_stderr = matcher.has_substr(expected_message),
                    deps = ["//arene/base:units"],
                ),
            )
            for i, (args, expected_message) in enumerate([
                ("my_kind, int", "The specified parent kind must be a quantity kind"),
                ("my_kind, base_unit, my_origin", "The specified parent kind must not be a unit"),
                ("my_kind, base_unit, base_kind", "The specified parent kind must not be a unit"),
                ("my_kind, my_origin, base_kind", "The specified unit must be a quantity unit"),
                ("my_kind, int, base_kind", "The specified parent kind must be a quantity kind"),
                ("my_kind, int, my_origin", "The specified parent kind must be a quantity kind"),
                ("my_kind, my_origin, int", "The specified unit must be a quantity unit"),
                ("my_kind, base_kind, base_unit, my_origin", "The specified origin must be a quantity origin"),
                ("my_kind, my_origin, base_kind, base_unit", "The specified parent kind must be a quantity kind"),
                ("my_kind, base_unit, my_origin, base_kind", "The specified parent kind must not be a unit"),
                ("my_kind, int, my_origin, base_unit", "The specified parent kind must be a quantity kind"),
                ("my_kind, base_kind, int, base_unit", "The specified origin must be a quantity origin"),
                ("my_kind, base_kind, my_origin, int", "The specified unit must be a quantity unit"),
            ])
        ]
    ],
)

cc_build_error_test(
    name = "backward_relative_quantity_origin_error_test",
    src = inline_src.cpp("""\
    #include "arene/base/units.hpp"

    class my_origin : public arene::base::quantity_origin<my_origin> {};
    class relative_to_my_origin : public arene::base::relative_origin<relative_to_my_origin, my_origin> {};
    class base_kind : public arene::base::quantity_kind<base_kind, relative_to_my_origin> {};
    class child_kind : public arene::base::quantity_kind<child_kind, base_kind, my_origin> {};
    """),
    compile_stderr = matcher.has_substr("If the parent of a derived quantity kind has an origin, the derived kind's origin must be relative to it"),
    deps = ["//arene/base:units"],
)

