test_suite(
    name = "explicit_base_set_error_test",
    tests = [
        subtest
        for subtest, _ in [
            (
                "explicit_base_set_error_{}_test".format(i),
                cc_build_error_test(
                    name = "explicit_base_set_error_{}_test".format(i),
                    src = inline_src.cpp("""\
            #include "arene/base/units.hpp"

            class length : public arene::base::quantity_kind<length> {{}};

            auto main() -> int
            {{
                arene::base::units_detail::explicit_base_set<{type}>;
            }}
            """.format(
                        type = type,
                    )),
                    compile_stderr = matcher.has_substr("explicit base set cannot be determined for invalid quantity kind"),
                    deps = ["//arene/base:units"],
                ),
            )
            for i, type in enumerate([
                "int",
                "length*",
                "length&",
                "length&&",
            ])
        ]
    ],
)

