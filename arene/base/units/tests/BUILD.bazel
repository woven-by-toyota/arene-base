cc_build_error_test(
    name = "integer_scale_factor_error_test",
    src = inline_src.cpp("""\
    #include "arene/base/units.hpp"

    class my_kind : public arene::base::quantity_kind<my_kind> {};
    class my_unit : public arene::base::quantity_unit<my_unit, my_kind> {};

    using scaled = arene::base::scaled_unit<my_unit, int>;
    """),
    compile_stderr = matcher.has_substr("The scale factor must be a ratio or a class wrapping a floating point scale"),
    deps = ["//arene/base:units"],
)

cc_build_error_test(
    name = "class_scale_factor_error_test",
    src = inline_src.cpp("""\
    #include "arene/base/units.hpp"

    class my_kind : public arene::base::quantity_kind<my_kind> {};
    class my_unit : public arene::base::quantity_unit<my_unit, my_kind> {};
    class some_class{};

    using scaled = arene::base::scaled_unit<my_unit, some_class>;
    """),
    compile_stderr = matcher.has_substr("The scale factor must be a ratio or a class wrapping a floating point scale"),
    deps = ["//arene/base:units"],
)

cc_build_error_test(
    name = "infinite_scale_factor_error_test",
    src = inline_src.cpp("""\
    #include "arene/base/units.hpp"
    #include "arene/base/stdlib_choice/numeric_limits.hpp"

    class my_kind : public arene::base::quantity_kind<my_kind> {};
    class my_unit : public arene::base::quantity_unit<my_unit, my_kind> {};
    class some_class{
    public:
      static constexpr double value = std::numeric_limits<double>::infinity();
    };

    using scaled = arene::base::scaled_unit<my_unit, some_class>;
    """),
    compile_stderr = matcher.has_substr("The scale factor must be a ratio or a class wrapping a floating point scale"),
    deps = [
        "//arene/base:units",
        "//arene/base/stdlib_choice:numeric_limits",
    ],
)

