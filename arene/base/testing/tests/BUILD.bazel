cc_binary(
    name = "prng_xoshiro_dump",
    testonly = True,
    srcs = ["prng_xoshiro_dump.cpp"],
    # This binary is only used as a genrule tool during the execution phase
    target_compatible_with = HOST_CONSTRAINTS,
    deps = [
        "//arene/base/testing:prng_xoshiro",
        "//configs:incompatible_with_toolchain_stdlib_disabled",
    ],
)

rust_binary(
    name = "rand_xoshiro256plusplus_dump_base",
    testonly = True,
    srcs = ["rand_xoshiro256plusplus_dump.rs"],
    edition = "2018",
    tags = ["manual"],
    # This binary is only used as a genrule tool during the execution phase
    target_compatible_with = HOST_CONSTRAINTS,
    deps = [
        "@crates//:libc",
        "@crates//:rand_xoshiro",
    ],
)


alias(
    name = "rand_xoshiro256plusplus_dump",
    actual = select({
        # OSS build does not use hermetic toolchains
        "//conditions:default": "rand_xoshiro256plusplus_dump_base",
    }),
    tags = ["manual"],
)

_TEST_SEEDS_U64 = [
    0,
    1,
    42,
    0xfedcba9876543210,
]

_TEST_SIZE = "256M"

[
    genrule(
        name = name,
        testonly = True,
        outs = [name + ".txt"],
        cmd = "$(location :{binary}) {seed} | head -c {size} > $@".format(
            size = size,
            binary = binary,
            seed = seed,
        ),
        tools = [":" + binary],
    )
    for binary in [
        "prng_xoshiro_dump",
        "rand_xoshiro256plusplus_dump",
    ]
    for seed in _TEST_SEEDS_U64
    for size in [_TEST_SIZE]
    for name in [
        "{}_seed_{}_size_{}_data".format(
            binary,
            seed,
            size,
        ),
    ]
]

test_suite(
    name = "xoshiro_reference_test",
    tests = [
        name
        for seed in _TEST_SEEDS_U64
        for size in [_TEST_SIZE]
        for name in ["xoshiro_seed_{}_reference_test".format(seed)]
        for _ in [diff_test(
            name = name,
            file1 = ":{}_seed_{}_size_{}_data".format(
                "prng_xoshiro_dump",
                seed,
                size,
            ),
            file2 = ":{}_seed_{}_size_{}_data".format(
                "rand_xoshiro256plusplus_dump",
                seed,
                size,
            ),
        )]
    ],
)

