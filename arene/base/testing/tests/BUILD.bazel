cc_build_error_test(
    name = "bitwise_uniform_distribution_nonzero_min_test",
    src = inline_src.cpp("""\
#include "arene/base/testing/bitwise_uniform_distribution.hpp"
#include "arene/base/testing/prng_xoshiro.hpp"
class prng_with_min : public arene::base::testing::prng_xoshiro {
 public:
  static constexpr auto min() noexcept -> std::uint64_t { return 8U; }
};
auto main() -> int {
  arene::base::testing::bitwise_uniform_distribution<int> dist{};
  prng_with_min prng{};
  return dist(prng);
}
"""),
    compile_stderr = matcher.contains_extended_regex(
        "error: {static_assert} failed{requirement}".format(
            requirement = "( due to requirement 'prng_with_min::min\\(\\) == unsigned long\\{\\}')?",
            static_assert = "(static_assert|static assertion)",
        ),
    ),
    deps = [
        "//arene/base/testing:bitwise_uniform_distribution",
        "//arene/base/testing:prng_xoshiro",
    ],
)

cc_build_error_test(
    name = "bitwise_uniform_distribution_lower_max_test",
    src = inline_src.cpp("""\
#include "arene/base/testing/bitwise_uniform_distribution.hpp"
#include "arene/base/testing/prng_xoshiro.hpp"
class prng_with_max : public arene::base::testing::prng_xoshiro {
 public:
  static constexpr auto max() noexcept -> std::uint64_t { return 255U; }
};
auto main() -> int {
  arene::base::testing::bitwise_uniform_distribution<int> dist{};
  prng_with_max prng{};
  return dist(prng);
}
"""),
    compile_stderr = matcher.contains_extended_regex(
        "error: {static_assert} failed{requirement}".format(
            requirement = "( due to requirement 'prng_with_max::max\\(\\) == static_cast<unsigned long>\\(~unsigned long\\{\\}\\)')?",
            static_assert = "(static_assert|static assertion)",
        ),
    ),
    deps = [
        "//arene/base/testing:bitwise_uniform_distribution",
        "//arene/base/testing:prng_xoshiro",
    ],
)
