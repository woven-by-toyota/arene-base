    visibility = [
        "//tools/compdb:__subpackages__",
    ],
    deps = [
        "//arene/base/byte:internal",
        "//arene/base/stdlib_choice:climits",
        "//arene/base/stdlib_choice:cstdint",
        "//arene/base/stdlib_choice:is_copy_assignable",
        "//arene/base/stdlib_choice:is_copy_constructible",
        "//arene/base/stdlib_choice:is_default_constructible",
        "//arene/base/stdlib_choice:is_destructible",
        "//arene/base/stdlib_choice:is_move_assignable",
        "//arene/base/stdlib_choice:is_move_constructible",
        "//arene/base/stdlib_choice:is_trivially_copyable",
        "//arene/base/stdlib_choice:numeric_limits",
        "//arene/base/testing:gtest",
        "//arene/base/type_list:remove_duplicates",
        "//testlibs:gtest",
    ],
)

cc_test_with_variants(
