cc_library_with_variants(
    name = "test_helpers",
    testonly = True,
    hdrs = ["test_helpers.hpp"],
    visibility = ["//arene/base/linalg:__subpackages__"],
    deps = [
        "//arene/base/mdspan",
        "//arene/base/mdspan:extents",
        "//arene/base/mdspan:layout",
        "//arene/base/stdlib_choice:cstddef",
        "//arene/base/stdlib_choice:cstdint",
        "//arene/base/type_list",
        "//arene/base/type_list:apply_each",
        "//arene/base/type_list:filter",
        "//arene/base/type_list:flat_map",
        "//arene/base/type_list:size",
        "//arene/base/type_traits:disjunction",
        "//testlibs:gtest",
        "//testlibs/utilities:configurable_value",
    ],
)

cc_test_with_variants(
    name = "math_traits_test",
    srcs = ["math_traits_test.cpp"],
    deps = [
        ":test_helpers",
        "//arene/base:constraints",
        "//arene/base/linalg:math_traits",
        "//arene/base/testing:gtest",
        "//testlibs:gtest",
    ],
)

cc_test_with_variants(
    name = "object_traits_test",
    srcs = ["object_traits_test.cpp"],
    deps = [
        ":test_helpers",
        "//arene/base/linalg:object_traits",
        "//arene/base/mdspan",
        "//arene/base/testing:gtest",
        "//testlibs:gtest",
    ],
)
