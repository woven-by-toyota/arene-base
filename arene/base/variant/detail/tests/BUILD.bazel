load("//rules:cc_test.bzl", "cc_test_with_variants")

# This test doesn't actually have exception-disabled dependent behavior in it. But we want to ensure that it builds with exceptions disabled, so we manually set `-fno-exceptions` here.
cc_test_with_variants(
    name = "bad_variant_access_exceptions_disabled_test",
    srcs = ["bad_variant_access_exceptions_disabled_test.cpp"],
    cxxopts = [
        "-fno-exceptions",
    ],
    deps = [
        "//arene/base/variant/detail:bad_variant_access",
        "//testlibs:death_test_support",
        "//testlibs:gtest",
    ],
)

cc_test_with_variants(
    name = "bad_variant_access_exceptions_enabled_test",
    srcs = ["bad_variant_access_exceptions_enabled_test.cpp"],
    deps = [
        "//arene/base/variant/detail:bad_variant_access",
        "//configs:incompatible_with_exceptions_disabled",
        "//testlibs:gtest",
    ],
)

exports_files(
    glob(["*.cpp"]),
    visibility = ["//:__subpackages__"],
)
