load("//rules:cc_library_with_variants.bzl", "cc_library_with_variants")
load("//rules:cc_test.bzl", "cc_test", "cc_test_with_variants")
load(
    "//rules:transitions.bzl",
    "transition_use_exceptions",
)

package(default_visibility = ["//tools/compdb:__subpackages__"])

cc_test_with_variants(
    name = "traits_test",
    srcs = ["traits_test.cpp"],
    deps = [
        "//arene/base:monostate",
        "//arene/base/stdlib_choice:cstdint",
        "//arene/base/stdlib_choice:numeric_limits",
        "//arene/base/testing:gtest",
        "//arene/base/variant:traits",
        "//testlibs:gtest",
    ],
)

cc_library_with_variants(
    name = "variant_get_exceptions_disabled_test",
    testonly = True,
    srcs = ["variant_get_exceptions_disabled_test.cpp"],
    tags = ["nocompdb"],
    target_compatible_with = select({
        "//configs:exceptions_disabled": [],
        "//configs:exceptions_enabled": ["@platforms//:incompatible"],
    }),
    deps = [
        "//arene/base:contracts",
        "//arene/base/stdlib_choice:cstddef",
        "//arene/base/stdlib_choice:move",
        "//arene/base/variant",
        "//testlibs:death_test_support",
        "//testlibs:gtest",
    ],
    alwayslink = True,
)

cc_test(
    name = "variant_get_exceptions_disabled_by_cxxopt_test",
    cxxopts = ["-fno-exceptions"],
    deps = [
        ":variant_get_exceptions_disabled_test",
    ],
)

transition_use_exceptions(
    name = "variant_get_exceptions_disabled_by_use_exceptions_test_wrapper",
    testonly = True,
    src = ":variant_get_exceptions_disabled_test",
    value = False,
)

cc_test(
    name = "variant_get_exceptions_disabled_by_flag_test",
    deps = [
        ":variant_get_exceptions_disabled_by_use_exceptions_test_wrapper",
    ],
)

cc_test_with_variants(
    name = "variant_get_exceptions_enabled_test",
