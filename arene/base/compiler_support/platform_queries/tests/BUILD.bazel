cc_library_with_variants(
    name = "exception_check_test_source",
    testonly = True,
    srcs = ["exceptions_enabled_or_disabled_test.cpp"],
    cxxopts = select({
        "//configs:exceptions_enabled": [""],
        "//configs:exceptions_disabled": ["-fno-exceptions"],
    }),
    defines = select({
        "//configs:exceptions_enabled": ["TEST_EXCEPTIONS_ENABLED=1"],
        "//configs:exceptions_disabled": ["TEST_EXCEPTIONS_ENABLED=0"],
    }),
    deps = [
        "//arene/base/compiler_support:internal",
        "//testlibs:gtest",
    ],
    alwayslink = True,
)

transition_use_exceptions(
    name = "exceptions_check_exceptions_disabled",
    testonly = True,
    src = ":exception_check_test_source",
    value = False,
)

cc_test_with_variants(
    name = "exceptions_disabled_by_flag",
    deps = [
        ":exceptions_check_exceptions_disabled",
    ],
)

cc_test_with_variants(
    name = "exceptions_default_for_platform",
    deps = [
        ":exception_check_test_source",
