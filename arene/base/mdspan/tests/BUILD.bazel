cc_build_error_test(
    name = "mdspan_checks_mapping_access_postcondition_test",
    src = inline_src.cpp("""\
#include "arene/base/mdspan/layout.hpp"
#include "arene/base/mdspan/mdspan.hpp"
#include "arene/base/stdlib_choice/cstdint.hpp"
#include "arene/base/stdlib_choice/ignore.hpp"
#include "arene/base/stdlib_choice/numeric_limits.hpp"

struct bad_layout
{
  using base_layout = arene::base::layout_right;

  template <class Extents>
  struct mapping : public base_layout::template mapping<Extents> {
    using base_mapping = typename base_layout::template mapping<Extents>;
    static_assert(std::is_same<std::uint64_t, typename Extents::index_type>::value, "");

   public:
    using base_mapping::base_mapping;

    template <class... OtherIndexArgs>
    constexpr auto operator()(OtherIndexArgs&&...) const noexcept
    {
      // this value does *not* satify the postcondition requirements of a mapping
      return std::uint64_t{std::numeric_limits<std::size_t>::max()} + std::uint64_t{1};
    }
  };
};

static_assert(
  sizeof(std::size_t) < sizeof(std::uint64_t),
  "this test is only intended for 32-bit platforms"
);

auto main() -> int
{
  using extents_type = arene::base::extents<std::uint64_t>;
  static constexpr auto value = int{};
  constexpr auto _ = arene::base::mdspan<int const, extents_type, bad_layout>{&value}();
  std::ignore = _;
}
"""),
    compile_stderr = matcher.contains_basic_regex("error.*contract_violation"),
