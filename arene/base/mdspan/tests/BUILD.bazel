[
    cc_build_error_test(
        name = "default_accessor_element_type_{}_test".format(i),
        src = inline_src.cpp("""\
#include "arene/base/mdspan/default_accessor.hpp"

class abstract
{{
    virtual ~abstract() = 0;
}};

auto main() -> int
{{
  arene::base::default_accessor<{element_type}>{{}};
}}
""".format(
            element_type = param["element_type"],
        )),
        compile_stderr = matcher.contains_extended_regex(
            "error: {static_assert} failed{requirement}{sep}{diagnostic}".format(
                diagnostic = param["diagnostic"],
                requirement = "( due to requirement '{}')?".format(param["requirement"]),
                sep = "(: | \")",
                static_assert = "(static_assert|static assertion)",
            ),
        ),
        deps = [
            "//arene/base/mdspan:default_accessor",
        ],
    )
    for i, param in enumerate([
        {
            "element_type": "int&",
            "diagnostic": "'ElementType' must be an object",
            "requirement": "std::is_object<.*>::value",
        },
        {
            "element_type": "abstract",
            "diagnostic": "'ElementType' must not be an abstract class",
            "requirement": "!std::is_abstract<.*>::value",
        },
        {
            "element_type": "int[]",
            "diagnostic": "'ElementType' must not be an array",
            "requirement": "!std::is_array<.*>::value",
        },
    ])
]

# Death tests are not yet supported for Cortex-R52 but we need to test this now.
# We specifically want to test platforms where 'std::size_t' is 32-bits to
# ensure that we are not silently clipping integer values.
#
cc_build_error_test(
    name = "extent_value_exceed_size_t_test",
    src = inline_src.cpp(
        """\
#include "arene/base/array/array.hpp"
#include "arene/base/mdspan/extents.hpp"
#include "arene/base/stdlib_choice/cstddef.hpp"
#include "arene/base/stdlib_choice/cstdint.hpp"
#include "arene/base/stdlib_choice/ignore.hpp"

auto main() -> int
{
  using extents_type = arene::base::extents<std::size_t, arene::base::dynamic_extent, 1U>;
  constexpr auto not_always_representable_with_size_t = (std::uint64_t{1U} << 32U) | std::uint64_t{1U};

  static constexpr auto x = extents_type{arene::base::array<std::uint64_t, 2>{
    // dimension 0 has a dynamic extent so any value is okay
    42U,
    // dimension 1 *must* match the static extent value of 1
    // and we need to test that the value is not silently converted to
    // 'std::size_t' on 32-bit systems
    not_always_representable_with_size_t
  }};

  std::ignore = x;
}
""",
    ),
    compile_stderr = matcher.has_substr("contract_violation"),
    deps = [
        "//arene/base:array",
        "//arene/base/mdspan:extents",
        "//arene/base/stdlib_choice:cstddef",
        "//arene/base/stdlib_choice:cstdint",
        "//arene/base/stdlib_choice:ignore",
    ],
)

