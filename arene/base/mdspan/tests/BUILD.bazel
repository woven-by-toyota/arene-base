[
    cc_build_error_test(
        name = "extents_requires_static_extent_in_range_of_index_type_{}_test".format(i),
        src = inline_src.cpp(
            """\
#include "arene/base/mdspan/extents.hpp"
#include "arene/base/stdlib_choice/cstdint.hpp"
#include "arene/base/stdlib_choice/numeric_limits.hpp"

auto main() -> int
{{
  arene::base::extents<{type}, {value}>{{}};
}}
    """.format(
                type = type,
                value = value,
            ),
        ),
        compile_stderr = matcher.has_substr("invalid template parameters for 'extents'"),
        deps = [
            "//arene/base/mdspan:extents",
            "//arene/base/stdlib_choice:cstdint",
            "//arene/base/stdlib_choice:numeric_limits",
        ],
    )
    for i, (type, value) in enumerate([
        ("std::int8_t", 128),
        ("std::uint8_t", 256),
        # NOTE `numeric_limits<uint32_t>::max()` is *equal* to `dynamic_extent` on 32-bit platforms
        ("std::int32_t", "std::numeric_limits<std::uint32_t>::max() - std::uint32_t{1}"),
    ])
]

cc_build_error_test(
    name = "make_extents_with_value_not_representable_in_std_size_t",
    src = inline_src.cpp(
        """\
#include "arene/base/mdspan/extents.hpp"
#include "arene/base/stdlib_choice/integral_constant.hpp"
#include "arene/base/stdlib_choice/cstddef.hpp"

auto main() -> int
{
  arene::base::make_extents(std::integral_constant<std::uint64_t, (std::size_t(-1)) + std::uint64_t{1}>{});
}
""",
    ),
    compile_stderr = matcher.has_substr("error: narrowing conversion of"),
    target_compatible_with = [
        "@platforms//cpu:cortex-r52",
