load("//rules:cc_build_error.bzl", "cc_build_error_test", "matcher")
load("//rules:cc_test.bzl", "cc_test_with_variants")

cc_test_with_variants(
    name = "bind_front_test",
    srcs = [
        "bind_front_test.cpp",
    ],
    visibility = [
        "//tools/compdb:__subpackages__",
    ],
    deps = [
        "//arene/base:constraints",
        "//arene/base:optional",
        "//arene/base/compiler_support:cpp14_inline",
        "//arene/base/functional:bind_front",
        "//arene/base/stdlib_choice:cstddef",
        "//arene/base/stdlib_choice:declval",
        "//arene/base/stdlib_choice:enable_if",
        "//arene/base/stdlib_choice:ignore",
        "//arene/base/stdlib_choice:initializer_list",
        "//arene/base/stdlib_choice:minus",
        "//arene/base/stdlib_choice:move",
        "//arene/base/stdlib_choice:plus",
        "//arene/base/stdlib_choice:reference_wrapper",
        "//arene/base/testing:gtest",
        "//arene/base/type_traits:is_invocable",
        "//testlibs:gtest",
    ],
)

cc_build_error_test(
    name = "bound_arguments_must_be_capturable",
    src = "bound_arguments_must_be_capturable.cpp",
    compile_stderr = matcher.has_substr("Bound arguments must be capturable from input."),
    deps = ["//arene/base/functional:bind_front"],
)

cc_build_error_test(
    name = "bound_arguments_must_be_move_constructable_test",
    src = "bound_arguments_must_be_move_constructable_test.cpp",
    compile_stderr = matcher.has_substr("Bound arguments must be move-constructible."),
    deps = ["//arene/base/functional:bind_front"],
)

cc_build_error_test(
    name = "function_object_must_be_move_constructable_test",
    src = "function_object_must_be_move_constructable_test.cpp",
    compile_stderr = matcher.has_substr("Bound function must be move-constructible."),
    deps = ["//arene/base/functional:bind_front"],
)

cc_build_error_test(
    name = "not_constructable_from_function_test",
    src = "not_constructable_from_function_test.cpp",
    compile_stderr = matcher.has_substr("Bound function must be constructible from input."),
    deps = ["//arene/base/functional:bind_front"],
)

exports_files(
    glob(["*.cpp"]),
    visibility = ["//:__subpackages__"],
)
