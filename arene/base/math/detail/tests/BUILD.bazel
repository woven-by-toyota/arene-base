load("//rules:cc_build_error.bzl", "cc_build_error_test", "inline_src", "matcher")
load("//rules:cc_test.bzl", "cc_test_with_variants")

cc_test_with_variants(
    name = "abs_float_test_builtin",
    srcs = ["abs_float_test.cpp"],
    defines = ["ARENE_BASE_MATH_DETAIL_USE_BUILTIN_ABS_FLOAT"],
    deps = [
        "//arene/base/compiler_support",
        "//arene/base/math:internal",
        "//arene/base/testing:gtest",
        "//testlibs:gtest",
    ],
)

cc_test_with_variants(
    name = "abs_float_test_custom",
    srcs = ["abs_float_test.cpp"],
    deps = [
        "//arene/base/compiler_support",
        "//arene/base/math:internal",
        "//arene/base/testing:gtest",
        "//testlibs:gtest",
    ],
)

cc_test_with_variants(
    name = "abs_if_needed_test",
    srcs = ["abs_if_needed_test.cpp"],
    deps = [
        "//arene/base/compiler_support:diagnostics",
        "//arene/base/math:abs",
        "//arene/base/math:float_properties",
        "//arene/base/math:float_sign",
        "//arene/base/math/detail:abs_if_needed",
        "//arene/base/testing:gtest",
        "//testlibs:gtest",
        "//testlibs/utilities:common_test_types",
    ],
)

cc_test_with_variants(
    name = "abs_if_needed_death_test",
    srcs = ["abs_if_needed_death_test.cpp"],
    deps = [
        "//arene/base/math/detail:abs_if_needed",
        "//testlibs:death_test_support",
        "//testlibs:gtest",
        "//testlibs/utilities:common_test_types",
    ],
)

cc_build_error_test(
    name = "abs_if_needed_no_abs_defined_test",
    src = inline_src.cpp("""\
#include "arene/base/math/detail/abs_if_needed.hpp"

struct type_without_abs{};

auto main() -> int
{
  arene::base::math_detail::abs_if_needed(type_without_abs{});
}
"""),
    compile_stderr = matcher.contains_basic_regex(
        select({
            "//conditions:default": "error: no matching function for call to object of type",
            "//configs/compiler:gcc_or_qcc": "error: no match for call to '(const arene::base::math_detail::abs_if_needed_impl) (type_without_abs)'",
        }),
    ),
    deps = [
        "//arene/base/math/detail:abs_if_needed",
    ],
)

exports_files(
    glob(["*.cpp"]),
    visibility = ["//:__subpackages__"],
)
