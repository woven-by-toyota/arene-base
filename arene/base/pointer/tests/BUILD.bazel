        "//arene/base/stdlib_choice:is_trivially_copyable",
        "//arene/base/stdlib_choice:remove_reference",
        "//arene/base/stdlib_choice:tuple",
        "//testlibs:gtest",
    ],
)

cc_test_with_variants(
    name = "non_owning_ptr_death_test",
    srcs = ["non_owning_ptr_death_test.cpp"],
    deps = [
        "//arene/base:array",
        "//arene/base:pointer",
        "//arene/base/stdlib_choice:tuple",
        "//testlibs:death_test_support",
        "//testlibs:gtest",
    ],
)

