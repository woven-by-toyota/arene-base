    srcs = ["non_owning_ptr_test.cpp"],
    deps = [
        "//arene/base:array",
        "//arene/base:pointer",
        "//arene/base/stdlib_choice:declval",
        "//arene/base/stdlib_choice:hash",
        "//arene/base/stdlib_choice:is_destructible",
