cc_library_with_variants(
    name = "internal",
    visibility = [
        ":__subpackages__",
        "//arene/base:__pkg__",
    ],
    deps = [
        ":compare_three_way",
        ":operators",
        ":strong_ordering",
    ],
)

filegroup(
    name = "package",
    srcs = [
        "BUILD.bazel",
        ":compare_three_way_hdrs",
        ":operators_hdrs",
        ":strong_ordering_hdrs",
    ],
    visibility = ["//arene/base:__pkg__"],
)
