cc_library_with_variants(
    name = "internal",
    visibility = [
        ":__subpackages__",
        "//arene/base:__pkg__",
    ],
    deps = [
        ":advance",
        ":distance",
        ":next",
        ":prev",
        ":reverse_iterator",
    ],
)

filegroup(
    name = "package",
    srcs = [
        "BUILD.bazel",
        ":advance_hdrs",
        ":distance_hdrs",
        ":next_hdrs",
        ":prev_hdrs",
        ":reverse_iterator_hdrs",
    ],
    visibility = ["//arene/base:__pkg__"],
