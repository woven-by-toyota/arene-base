load("//rules:cc_library_with_variants.bzl", "cc_library_with_variants")

filegroup(
    name = "distance_hdrs",
    srcs = ["distance.hpp"],
)

cc_library_with_variants(
    name = "distance",
    hdrs = [":distance_hdrs"],
    visibility = [
        "//arene/base:__subpackages__",
        "//stdlib:__subpackages__",
    ],
    deps = [
        "//arene/base/stdlib_choice:iterator_tags",
        "//arene/base/stdlib_choice:iterator_traits",
    ],
)

filegroup(
    name = "advance_hdrs",
    srcs = ["advance.hpp"],
)

cc_library_with_variants(
    name = "advance",
    hdrs = [":advance_hdrs"],
    visibility = [
        "//arene/base:__subpackages__",
        "//stdlib:__subpackages__",
    ],
    deps = [
        "//arene/base:constraints",
        "//arene/base:contracts",
        "//arene/base/compiler_support:cpp14_inline",
        "//arene/base/stdlib_choice:cstddef",
        "//arene/base/stdlib_choice:enable_if",
        "//arene/base/stdlib_choice:iterator_tags",
        "//arene/base/stdlib_choice:iterator_traits",
        "//arene/base/type_traits:iterator_category_traits",
    ],
)

filegroup(
    name = "next_hdrs",
    srcs = ["next.hpp"],
)

cc_library_with_variants(
    name = "next",
    hdrs = [":next_hdrs"],
    visibility = [
        "//arene/base:__subpackages__",
