filegroup(
    name = "reverse_iterator_hdrs",
    srcs = [
        "detail/std_reverse_iterator_disabled.hpp",
        "detail/std_reverse_iterator_enabled.hpp",
        "reverse_iterator.hpp",
    ],
)

cc_library_with_variants(
    name = "reverse_iterator",
    hdrs = [":reverse_iterator_hdrs"],
    visibility = [
        "//arene/base:__subpackages__",
        "//stdlib:__subpackages__",
    ],
    deps = [
        ":distance",
        ":next",
        ":prev",
        "//arene/base:constraints",
        "//arene/base:contracts",
        "//arene/base/compare:compare_three_way",
        "//arene/base/compare:operators",
        "//arene/base/compare:strong_ordering",
        "//arene/base/compiler_support",
        "//arene/base/stdlib_choice:declval",
        "//arene/base/stdlib_choice:enable_if",
        "//arene/base/stdlib_choice:forward",
