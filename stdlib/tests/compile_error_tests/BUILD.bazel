load("//rules:cc_build_error.bzl", "cc_build_error_test", "inline_src", "matcher")
load(
    "//rules:transitions.bzl",
    "transition_use_toolchain_stdlib",
)

# Check that the tests in `//stdlib/tests` fail to compile if the standard
# library headers are included using system includes
#
cc_build_error_test(
    name = "system_include_style_errs_with_stdlib_in_tests_test",
    src = inline_src.cpp("""\
#include <type_traits>
"""),
    compile_stderr = matcher.has_substr("error \"Include of standard library header <type_traits>\""),
    deps = ["//stdlib/tests:testing_stdlib"],
)

# stdlib target that flips `//configs:use_toolchain_stdlib` to `False`
#
transition_use_toolchain_stdlib(
    name = "testing_stdlib",
    src = "//stdlib",
    value = False,
)

# NOTE
# C++TestPro does not run on these tests as they do not compile. These tests
# should use system includes - as we would expect a consumer to do.
#
cc_build_error_test(
    name = "finds_internal_stdlib_instead_of_toolchain_stdlib_test",
    src = inline_src.cpp("""\
#include <vector>
"""),
    compile_stderr = matcher.has_substr("error \"Include of standard library header <vector>\""),
    deps = [":testing_stdlib"],
)

[
    cc_build_error_test(
        name = "integer_sequence_with_{}_test".format(category),
        src = inline_src.cpp(
            """\
#include <utility>
auto x = std::integer_sequence<{}>{{}};
""".format(non_integer_type),
        ),
        compile_stderr = matcher.contains_basic_regex(
            select({
                "//configs/compiler:arm_clang": "static_assert failed.* \"'Type' must be an integer.",
                "//conditions:default": "static assertion failed.*: 'Type' must be an integer.",
            }),
        ),
        deps = [":testing_stdlib"],
    )
    for category, non_integer_type in [
        ("nullptr_t", "decltype(nullptr)"),
        ("pointer", "int*"),
        ("reference", "int&"),
    ]
]

