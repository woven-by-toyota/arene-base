cc_build_error_test(
    name = "time_point_with_non_duration",
    src = inline_src.cpp("""\
#include "stdlib/include/chrono"
struct dummy_clock {
  using rep = long;
  using period = std::ratio<1>;
  using duration = std::chrono::duration<rep, period>;
  using time_point = std::chrono::time_point<dummy_clock>;

  static constexpr bool is_steady{true};

  static constexpr auto now() noexcept -> time_point { return {}; }
};

constexpr auto _ = std::chrono::time_point<dummy_clock, int>{};
"""),
    compile_stderr = matcher.contains_extended_regex(
        "The Duration of a std::time_point must be an instance of std::chrono::duration",
    ),
    deps = [":testing_stdlib"],
)
