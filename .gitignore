# we don't track the lock file
MODULE.bazel.lock

# override bazelisk home directory
.bazelisk/

# ignore all bazel-* symlinks.
/bazel-*

# ignore standard local bazelrc file
# https://bazel.build/configure/best-practices#bazelrc-file
user.bazelrc

# ignore generated files used to bootstrap bazelisk
.bazel-wrapper/
